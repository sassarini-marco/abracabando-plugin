# Python
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/

# Benchmark artifacts — keep prompts.json, run_benchmark.py, REPORT.md and the
# small per-query .json summaries; ignore the large raw transcripts and run logs.
bench/results/*.jsonl
bench/results/_*.log

# Local MCP bulk cache (if ever placed in-repo)
.cache/
*.parquet

# IDE / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local Claude Code user settings (never commit)
.claude/

# Eval harness run outputs (transient -- do not commit)
bench/eval_results/

# Frozen replay fixtures MUST be committed (they are the deterministic gate's
# recorded data). Un-ignore them explicitly in case a broader rule ever matches.
!bench/fixtures/
!bench/fixtures/**
